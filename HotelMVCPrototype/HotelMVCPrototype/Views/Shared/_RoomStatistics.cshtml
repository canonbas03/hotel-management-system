@model HotelMVCPrototype.Models.RoomStatisticsViewModel

<div class="row" style="background-color:#F0F4F2; border-radius:10px;">
    <div class="col-md-3 mb-3">
        <div class="card text-center shadow-sm" style="background-color:#FFFFFF;">
            <div class="card-body">
                <h6 style="color:#164E63;">Available</h6>
                <h3 id="stat-available" style="color:#164E63;">@Model.Available</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card text-center shadow-sm" style="background-color:#FFFFFF;">
            <div class="card-body">
                <h6 style="color:#86A789;">Occupied</h6>
                <h3 id="stat-occupied" style="color:#86A789;">@Model.Occupied</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card text-center shadow-sm" style="background-color:#FFFFFF;">
            <div class="card-body">
                <h6 style="color:#D97706;">Cleaning</h6>
                <h3 id="stat-cleaning" style="color:#D97706;">@Model.Cleaning</h3> 
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card text-center shadow-sm" style="background-color:#FFFFFF;">
            <div class="card-body">
                <h6 style="color:#B91C1C;">Maintenance</h6>
                <h3 id="stat-maintenance" style="color:#B91C1C;">@Model.Maintenance</h3> 
            </div>
        </div>
    </div>
</div>
